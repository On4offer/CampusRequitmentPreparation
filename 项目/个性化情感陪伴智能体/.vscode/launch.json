{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI (uvicorn)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--reload",
        "--host", "127.0.0.1",
        "--port", "8076"
      ],
      "cwd": "${workspaceFolder}",
      "jinja": true,
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ]
}
