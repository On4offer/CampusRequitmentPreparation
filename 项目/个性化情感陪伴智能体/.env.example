# OpenAI-compatible endpoint (DeepSeek/通义/百炼 等通常提供兼容形态)
LLM_BASE_URL=https://api.openai.com
LLM_API_KEY=sk-your-key
LLM_MODEL=gpt-4o-mini

# Server
HOST=0.0.0.0
PORT=8000

# Debug: include more info in /chat response
DEBUG=false

# ---------- V1 可选配置（不填则用代码内默认） ----------
# 共情策略从文件加载：填相对项目根的路径，如 config/policy_config.json；空则用内置默认
# POLICY_CONFIG_PATH=

# 情绪落盘：为情绪曲线/回访预留，写入 JSONL；默认关闭
# EMOTION_LOG_ENABLED=false
# EMOTION_LOG_PATH=data/emotion_log.jsonl

# 策略开关：默认 true；改为 false 可关闭“高风险强制倾听”或“关注档优先倾听”
# SAFETY_FORCE_LISTEN=true
# WATCH_TIER_FORCE_LISTEN=true

# ---------- V2 可选配置（最小 RAG） ----------
# 是否开启 RAG 检索（默认 false，先做灰度）
# RAG_ENABLED=false
# RAG_TOP_K=3
# RAG_MIN_SCORE=0.0
# RAG_MAX_CHARS=1200
