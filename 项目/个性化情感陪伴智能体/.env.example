# 使用说明：复制为 .env 后，只有「行首没有 #」的 KEY=value 会被加载。
# 下面大量以 # 开头的行是「可选功能示例」：需要某项时，去掉该行开头的 # 并填写正确值；保持注释则走代码里的默认行为。
#
# OpenAI-compatible endpoint (DeepSeek/通义/百炼 等通常提供兼容形态)
# 若直连 api.openai.com 报 403 unsupported_country_region_territory：说明官方 API 不支持当前地区，请改用境内可访问的兼容网关，勿改代码。
LLM_BASE_URL=https://api.openai.com
LLM_API_KEY=sk-your-key
LLM_MODEL=gpt-4o-mini

# Server（uvicorn 端口以命令行为准；此处与文档、Vite 默认代理对齐，避免新人联调对不上）
# 推荐本地：python -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8076
# web/vite.config.ts 默认将 /api 代理到 http://127.0.0.1:8076；若改端口请同步 web/.env 的 VITE_DEV_API_TARGET
HOST=0.0.0.0
PORT=8076

# 二期 Web：浏览器跨域 Origin 列表（逗号分隔）；留空则默认允许 Vite 开发端口 5173/4173
# CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Debug: include more info in /chat response
DEBUG=false

# ---------- V1 可选配置（不填则用代码内默认） ----------
# 共情策略从文件加载：填相对项目根的路径，如 config/policy_config.json；空则用内置默认
# POLICY_CONFIG_PATH=

# 情绪落盘：为情绪曲线/回访预留，写入 JSONL；默认关闭
# EMOTION_LOG_ENABLED=false
# EMOTION_LOG_PATH=data/emotion_log.jsonl

# 策略开关：默认 true；改为 false 可关闭“高风险强制倾听”或“关注档优先倾听”
# SAFETY_FORCE_LISTEN=true
# WATCH_TIER_FORCE_LISTEN=true

# ---------- V2 可选配置（最小 RAG） ----------
# 是否开启 RAG 检索（默认 false，先做灰度）
# RAG_ENABLED=false
# RAG_TOP_K=3
# RAG_MIN_SCORE=0.0
# RAG_MAX_CHARS=1200

# ---------- V3 可选配置（工具调用） ----------
# 是否开启工具调用（默认 false）
# TOOL_ENABLED=false
# TOOL_TIMEOUT_S=5.0
# TOOL_RETRY_TIMES=1

# ---------- V4 可选配置（混合检索） ----------
# 是否开启混合检索（向量 + BM25）
# RAG_USE_HYBRID=false
# RAG_BM25_TOP_K=5
# RAG_FUSION_METHOD=rrf

# V4 Query 改写/重试：首次召回弱时改写 query 再检索
# RAG_REWRITE_ENABLED=false
# RAG_REWRITE_MIN_SCORE=0.0

# ---------- V5 可选配置（用户隔离） ----------
# 为 true 时：访问单条 trace/LTM、画像等必须带 user_id 且与资源归属一致
# STRICT_USER_ISOLATION=false

# V5 配额与限流（QUOTA_ENABLED=true 时生效；日额度为 0 表示不限制日预算）
# QUOTA_ENABLED=false
# QUOTA_TOKEN_PER_USER_PER_DAY=0
# QUOTA_QPS_PER_USER=0
# 二期：日预算在主 LLM 前将超限时，true=去掉 RAG 块并紧缩 system 后重试；false=仍返回 429
# QUOTA_DEGRADE_ON_EXHAUST=false
# 降级时追加在 system 末尾的短提示；空则使用内置省流句（亦可 PATCH /admin/config 热改）
# QUOTA_DEGRADE_SYSTEM_HINT=

# V5 内容安全：输入规则扫描 + 助手输出敏感词脱敏（默认 true）
# CONTENT_SAFETY_ENABLED=true
# CONTENT_SAFETY_FILTER_OUTPUT=true

# V5 反馈：POST /feedback；点踩/纠错可镜像到评测 JSONL
# FEEDBACK_ENABLED=true
# FEEDBACK_LOG_PATH=data/feedback.jsonl
# FEEDBACK_EVAL_MIRROR_ENABLED=true
# FEEDBACK_EVAL_LOG_PATH=data/feedback_for_eval.jsonl

# V5 运营热配置：启动时加载 HOT_CONFIG_PATH；PATCH /admin/config 写回并立即生效
# HOT_CONFIG_PATH=data/hot_config.json
# 非空则须请求头 X-Admin-Token；为空则仅本机可访问 /admin/config
# ADMIN_CONFIG_TOKEN=

# ---------- V1.1：隐式 LTM 抽取（默认关闭，避免未就绪时多耗 token）----------
# true 时：在满足「每 N 轮 assistant」且非安全模式时，额外调一次抽取 LLM，写入 LTM（source=dialogue_extract）并更新 RAG 索引
# LTM_EXTRACT_ENABLED=false
# 每完成 N 条 assistant 消息触发一次；<=0 表示不按轮次触发
# LTM_EXTRACT_EVERY_N_TURNS=3
# 单条置信度低于此值则丢弃；抽取 LLM 温度
# LTM_EXTRACT_MIN_CONFIDENCE=0.55
# LTM_EXTRACT_LLM_TEMPERATURE=0.2
# 单次最多写入条数；送入抽取模型的对话摘录最大字符数
# LTM_EXTRACT_MAX_ITEMS=5
# LTM_EXTRACT_CHAR_BUDGET=6000
# 与近期 LTM 文本相似度（归一化后 SequenceMatcher）：高于 skip 则跳过新建；介于 merge~skip 则 update 已有行
# LTM_EXTRACT_DEDUP_ENABLED=true
# LTM_EXTRACT_DEDUP_SKIP_RATIO=0.90
# LTM_EXTRACT_DEDUP_MERGE_RATIO=0.76
# LTM_EXTRACT_DEDUP_LOOKBACK=80
# QUOTA_ENABLED=true 时：抽取 LLM 是否计入日字符预算（预检 + 成功后扣减）；回复估算用于预检
# LTM_EXTRACT_COUNT_TOWARD_QUOTA=true
# LTM_EXTRACT_QUOTA_REPLY_ESTIMATE=400
# true 且配置 REDIS_URL 时：隐式抽取入 Redis 队列，由 uvicorn 进程内 BRPOP worker 执行（缩短对话尾延迟）；未配 Redis 则回退同步并打日志
# LTM_EXTRACT_ASYNC=false

# V1.1 P2：RAG 向量（OpenAI 兼容 embeddings）；留空则沿用稀疏本地向量
# RAG_EMBEDDING_API_BASE=https://api.openai.com/v1
# RAG_EMBEDDING_API_KEY=
# RAG_EMBEDDING_MODEL=text-embedding-3-small
# RAG_EMBEDDING_TIMEOUT_S=30

# ---------- 三期：Redis（STM）/ 关系库（LTM）----------
# 非空即启用：`app.memory.redis_stm.RedisSessionStore`、`app.memory.ltm_sql.SQLLTMStore`；留空则进程内内存实现。
# GET /health 会返回 redis / database 字段：skipped | ok | error
# REDIS_URL=redis://192.168.x.x:6379/0
# DATABASE_URL=mysql+pymysql://user:password@127.0.0.1:3306/companion
# DATABASE_URL=postgresql+psycopg://user:password@127.0.0.1:5432/companion
